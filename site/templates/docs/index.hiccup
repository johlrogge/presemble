[:html {:lang "en"}
  [:head
    [:meta {:charset "utf-8"}]
    [:meta {:name "viewport" :content "width=device-width, initial-scale=1"}]
    [:title "Presemble — Documentation"]
    [:link {:rel "stylesheet" :href "/assets/style.css"}]]
  [:body
    [:presemble/include {:src "header"}]
    [:main {:class "docs"}
      [:presemble/insert {:data "self.title" :as "h1"}]
      [:presemble/insert {:data "self.description" :as "p"}]
      [:ul {:class "docs__cards"}
        [:template {:data-each "guide"}
          [:li
            [:presemble/insert {:data "item.title" :as "h2"}]
            [:presemble/insert {:data "item.summary" :as "p"}]
            [:presemble/insert {:data "item.link"}]]]]]
    [:presemble/include {:src "footer"}]]]
