[:template {:presemble/define "body"}
  [:main
    [:presemble/include {:src "nav"}]
    [:presemble/insert {:data "input.title" :as "h1"}]
    [:ul
      [:template {:data-each "input.author"}
        [:li
          [:presemble/insert {:data "item.link" :as "h2"}]
          [:presemble/insert {:data "item.bio" :as "p"}]]]]]]

[:html {:lang "en"}
  [:head
    [:meta {:charset "utf-8"}]
    [:meta {:name "viewport" :content "width=device-width, initial-scale=1"}]
    [:title "Authors"]
    [:link {:rel "stylesheet" :href "/assets/style.css"}]]
  [:body
    ((juxt self/body) input)]]
